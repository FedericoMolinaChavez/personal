# Copy this file to `.env.local` and fill in real values.
# All of these are optional for the app to BUILD and RUN — without them it
# stays in "placeholder mode" (the Hire Me button shows a friendly notice and
# the booking widget shows a placeholder calendar).

# --- Stripe (server-side secret; never expose with NEXT_PUBLIC_) ---
# Get a test key at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx

# What the "Hire Me" checkout charges for — the $500 starter engagement
# (written build plan + 3 working sessions, or a basic MVP from scratch).
SERVICE_NAME=Build Plan & MVP Sprint
SERVICE_PRICE_USD=500

# Absolute base URL used for Stripe success/cancel redirects.
# Local: http://localhost:3000 — Production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Stripe webhook (for payment notifications) ---
# Generated in Stripe dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/webhook
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Resend (email notifications when someone pays) ---
# Get a free API key at https://resend.com (3,000 emails/month free)
# Verify your domain thenomadhub.xyz in Resend → Domains
RESEND_API_KEY=re_xxx
# Must match a verified sender address in your Resend account
RESEND_FROM_EMAIL=notifications@thenomadhub.xyz

# --- Cal.com booking (free, open-source) ---
# Your Cal.com event link in the form "username/event-slug".
# Sign up free at https://cal.com, create an event type, copy its slug.
NEXT_PUBLIC_CALCOM_LINK=yourhandle/consultation

# --- Supabase (shared DB for the agriculture tools) ---
# Local dev: values are printed by `npm run db:start` (supabase start).
# Hosted: Project Settings -> API. NEXT_PUBLIC_* are safe to expose to the browser
# (RLS-enforced); the service role key bypasses RLS and must stay server-only.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server only — bypasses RLS, never expose with NEXT_PUBLIC_

# --- LLM (P2 spray extraction; provider-agnostic wrapper in lib/shared/llm) ---
# Get an Anthropic key at https://console.anthropic.com. LLM_MODEL defaults to
# claude-sonnet-4-6 (strong vision, cheaper than Opus). Server-only.
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxx
LLM_MODEL=claude-sonnet-4-6

# --- Embeddings (P1 agronomy RAG) ---
# Anthropic has no embeddings endpoint, so document/query embeddings use OpenAI.
# text-embedding-3-small is 1536-dim, matching agronomy.chunks.embedding. Server-only.
# Get a key at https://platform.openai.com/api-keys.
OPENAI_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small

# --- Tools demo bypass (TEMPORARY — remove once Supabase Auth sign-in ships) ---
# When set, the tools skip the sign-in gate and act as this tenant. Use a tenant
# id that exists in public.tenants (see supabase/seed.sql).
DEMO_TENANT_ID=

# --- P2 spray intake webhook (deferred; SMS/WhatsApp) ---
# SPRAY_WEBHOOK_SECRET=
